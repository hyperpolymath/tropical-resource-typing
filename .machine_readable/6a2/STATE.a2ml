  { name = "Tropical",               loc = 279,  build = "GREEN", proof-failures = 0, doc-failures = 0,
    note = "Original baseline (not in ROOT — superseded by Tropical_v2)." },
  { name = "Tropical_Ordinal",       loc = 162,  build = "GREEN", proof-failures = 0, doc-failures = 0,
