# Smoke fixture: tropical (min-plus) determinant of [[1,2],[3,4]].
#
# By definition: det_min = min(1+4, 2+3) = min(5, 5) = 5.
# So the expected = 5 case should yield "oracle: agree".

[oracle-input]
family   = "tropical-determinant-min"
matrix   = [[1, 2], [3, 4]]
expected = 5
